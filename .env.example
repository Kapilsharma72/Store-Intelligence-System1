# PostgreSQL credentials
POSTGRES_USER=store_user
POSTGRES_PASSWORD=store_password

# Database connection URL (used by API and Alembic)
DATABASE_URL=postgresql://store_user:store_password@db:5432/store_intelligence

# API base URL (used by pipeline and dashboard)
API_BASE_URL=http://localhost:8000

# Path to the YOLOv8 model weights file
YOLO_MODEL_PATH=yolov8n.pt

# Minimum seconds a visitor must remain in a zone before a ZONE_DWELL event is emitted
DWELL_THRESHOLD_SECONDS=30

# Seconds a visitor can be in the billing queue without a POS transaction before BILLING_QUEUE_ABANDON is emitted
QUEUE_ABANDON_TIMEOUT_SECONDS=120
